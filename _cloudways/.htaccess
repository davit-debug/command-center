# =============================================================================
# 10xseo.ge — Cloudways production .htaccess
# Stack: Apache (behind Nginx + Varnish on Cloudways)
# Site type: Static HTML/CSS/JS (no PHP, no DB)
# =============================================================================

# -----------------------------------------------------------------------------
# 0) Force https:// in Location headers when client is on HTTPS via Cloudways' Nginx
#    Apache listens on HTTP locally (Cloudways terminates TLS at Nginx), so it
#    bakes "http://" into 301 Location headers. Rewriting http→https in the
#    outgoing Location header saves one HTTP→HTTPS hop per redirect.
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
    # Unconditional — Cloudways' Nginx is always HTTPS-terminated; any HTTP
    # client would already be 301'd to HTTPS before reaching Apache.
    Header always edit Location "^http://" "https://"
</IfModule>

# -----------------------------------------------------------------------------
# 1) HTTPS + canonical host (force https://10xseo.ge — strip www)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Strip www
    RewriteCond %{HTTP_HOST} ^www\.10xseo\.ge$ [NC]
    RewriteRule ^ https://10xseo.ge%{REQUEST_URI} [R=301,L]
</IfModule>

# -----------------------------------------------------------------------------
# 2) WordPress → static-HTML 301 redirects
#    Pattern: /slug/  →  /slug.html       (and /en/slug/ → /en/slug.html)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>

    # ----- Case studies (sub-directory; trailing slash → .html) -----
    RewriteRule ^case-studies/3x-in-28-days/?$                          https://%{HTTP_HOST}/case-studies/3x-in-28-days.html [R=301,L]
    RewriteRule ^case-studies/270-percent-increase/?$                   https://%{HTTP_HOST}/case-studies/270-percent-increase.html [R=301,L]
    RewriteRule ^case-studies/250-percent-increase/?$                   https://%{HTTP_HOST}/case-studies/250-percent-increase.html [R=301,L]
    RewriteRule ^case-studies/local-seo-result/?$                       https://%{HTTP_HOST}/case-studies/local-seo-result.html [R=301,L]
    RewriteRule ^case-studies/stomatologiuri-klinikis-seo/?$            https://%{HTTP_HOST}/case-studies/stomatologiuri-klinikis-seo.html [R=301,L]
    RewriteRule ^case-studies/4200-yoveltviuri-vizitori-4-tveshi/?$     https://%{HTTP_HOST}/case-studies/4200-yoveltviuri-vizitori-4-tveshi.html [R=301,L]
    RewriteRule ^case-studies/trafikis-gaormageba-3-tveshi/?$           https://%{HTTP_HOST}/case-studies/trafikis-gaormageba-3-tveshi.html [R=301,L]
    RewriteRule ^case-studies/seo-krizisidan-top-3mde/?$                https://%{HTTP_HOST}/case-studies/seo-crisis-management.html [R=301,L]

    # English case studies (slug differences)
    RewriteRule ^en/case-studies/doubled-traffic-in-3-months/?$         https://%{HTTP_HOST}/en/case-studies/trafikis-gaormageba-3-tveshi.html [R=301,L]

    # ----- Blog posts (WP /slug/ → CC /blog/slug.html) -----
    RewriteRule ^google-2024-core-update/?$                  https://%{HTTP_HOST}/blog/google-2024-core-update.html [R=301,L]
    RewriteRule ^interaction-to-next-paint/?$                https://%{HTTP_HOST}/blog/interaction-to-next-paint.html [R=301,L]
    RewriteRule ^seo-for-business/?$                         https://%{HTTP_HOST}/blog/seo-for-business.html [R=301,L]
    RewriteRule ^2024-seo-trendebi/?$                        https://%{HTTP_HOST}/blog/2024-seo-trendebi.html [R=301,L]
    RewriteRule ^seo-vs-ppc/?$                               https://%{HTTP_HOST}/blog/seo-vs-ppc.html [R=301,L]
    RewriteRule ^business-seo-stats/?$                       https://%{HTTP_HOST}/blog/business-seo-stats.html [R=301,L]
    RewriteRule ^google-sandbox/?$                           https://%{HTTP_HOST}/blog/google-sandbox.html [R=301,L]
    RewriteRule ^seo-content/?$                              https://%{HTTP_HOST}/blog/seo-content.html [R=301,L]
    RewriteRule ^2023-seo-stats/?$                           https://%{HTTP_HOST}/blog/2023-seo-stats.html [R=301,L]
    RewriteRule ^soc-media-da-seo/?$                         https://%{HTTP_HOST}/blog/soc-media-da-seo.html [R=301,L]
    RewriteRule ^link-building-stats/?$                      https://%{HTTP_HOST}/blog/link-building-stats.html [R=301,L]
    RewriteRule ^ra-dro-schireba-seos-shedegebis-misagebad/?$ https://%{HTTP_HOST}/blog/ra-dro-schireba-seos-shedegebis-misagebad.html [R=301,L]
    RewriteRule ^2025-wlis-martis-ganaxlebebi-dasrulda/?$    https://%{HTTP_HOST}/blog/2025-wlis-martis-ganaxlebebi-dasrulda.html [R=301,L]
    RewriteRule ^geotegirebis-gavlena-reitingze/?$           https://%{HTTP_HOST}/blog/geotegirebis-gavlena-reitingze.html [R=301,L]
    RewriteRule ^ratom-schirdeba-bizness-seo/?$              https://%{HTTP_HOST}/blog/ratom-schirdeba-bizness-seo.html [R=301,L]
    RewriteRule ^cifruli-marketingi/?$                       https://%{HTTP_HOST}/blog/cifruli-marketingi.html [R=301,L]
    RewriteRule ^ra-aris-aeo/?$                              https://%{HTTP_HOST}/blog/ra-aris-aeo.html [R=301,L]
    # /seo-saagento/ is an existing blog post — preserve URL semantics (blog → blog)
    RewriteRule ^seo-saagento/?$                             https://%{HTTP_HOST}/blog/seo-saagento.html [R=301,L]
    RewriteRule ^seo-2025/?$                                 https://%{HTTP_HOST}/blog/seo-2025.html [R=301,L]
    RewriteRule ^seo-2025-top-stories/?$                     https://%{HTTP_HOST}/blog/seo-2025-top-stories.html [R=301,L]
    RewriteRule ^how-instagram-detects-mood/?$               https://%{HTTP_HOST}/blog/how-instagram-detects-mood.html [R=301,L]
    RewriteRule ^brand-mistakes/?$                           https://%{HTTP_HOST}/blog/brand-mistakes.html [R=301,L]
    RewriteRule ^cifruli-memkvidreoba/?$                     https://%{HTTP_HOST}/blog/cifruli-memkvidreoba.html [R=301,L]
    RewriteRule ^2025-dzebnebi/?$                            https://%{HTTP_HOST}/blog/2025-dzebnebi.html [R=301,L]
    # /copywriting/ is an existing blog post on WP — keep blog → blog (user confirmed 2026-05-13)
    RewriteRule ^copywriting/?$                              https://%{HTTP_HOST}/blog/copywriting.html [R=301,L]
    RewriteRule ^local-seo/?$                                https://%{HTTP_HOST}/blog/local-seo.html [R=301,L]
    RewriteRule ^best-seo-agency-in-georgia/?$               https://%{HTTP_HOST}/blog/best-seo-agency-in-georgia.html [R=301,L]
    # CHANGED based on GSC: /ra-aris-seo/ has 81 clicks / 4,972 imp over 90 days — top traffic source.
    # Going to the top-level dual-intent service page (better conversion than pure blog).
    RewriteRule ^ra-aris-seo/?$                              https://%{HTTP_HOST}/ra-aris-seo.html [R=301,L]

    # English blog posts (mostly mirror GE slugs under /en/blog/)
    RewriteRule ^en/what-is-aeo/?$                           https://%{HTTP_HOST}/en/blog/what-is-aeo.html [R=301,L]
    # /en/how-instagram-detects-mood/ has matching EN blog file
    RewriteRule ^en/how-instagram-detects-mood/?$            https://%{HTTP_HOST}/en/blog/how-instagram-detects-mood.html [R=301,L]
    # /en/best-seo-agency-in-georgia/ — EN blog version doesn't exist; redirect to about-us
    # (7 clicks / 487 imp in GSC; "best agency" semantic match = company about page)
    RewriteRule ^en/best-seo-agency-in-georgia/?$            https://%{HTTP_HOST}/en/about-us.html [R=301,L]

    # ----- Static service / info pages (trailing slash → .html) -----
    RewriteRule ^seo-management/?$       https://%{HTTP_HOST}/seo-management.html [R=301,L]
    RewriteRule ^seo-audit/?$            https://%{HTTP_HOST}/seo-audit.html [R=301,L]
    RewriteRule ^seo-copywriting/?$      https://%{HTTP_HOST}/seo-copywriting.html [R=301,L]
    RewriteRule ^about-us/?$             https://%{HTTP_HOST}/about-us.html [R=301,L]
    RewriteRule ^contact-us/?$           https://%{HTTP_HOST}/contact-us.html [R=301,L]
    RewriteRule ^portfolio/?$            https://%{HTTP_HOST}/portfolio.html [R=301,L]
    RewriteRule ^blog/?$                 https://%{HTTP_HOST}/blog.html [R=301,L]
    RewriteRule ^seo-leqsikoni/?$        https://%{HTTP_HOST}/seo-leqsikoni.html [R=301,L]
    RewriteRule ^startup-leqsikoni/?$    https://%{HTTP_HOST}/startup-leqsikoni.html [R=301,L]
    RewriteRule ^case-studies/?$         https://%{HTTP_HOST}/case-studies.html [R=301,L]

    # ----- Pages with NO direct equivalent -----
    RewriteRule ^link-building/?$        https://%{HTTP_HOST}/seo-management.html [R=301,L]
    # /web-development/ — 10xSEO no longer offers web dev; 410 = honest deindex signal
    RewriteRule ^web-development/?$      - [G,L]
    RewriteRule ^get-an-offer/?$         https://%{HTTP_HOST}/contact-us.html [R=301,L]

    # ----- Pages discovered via Ahrefs (NOT in original sitemap) -----
    # /seo-optimizacia/ has 3 referring domains — currently redirects to /ra-aris-seo/ on WP
    # Keep the same target to preserve existing redirect chain & user expectations
    RewriteRule ^seo-optimizacia/?$      https://%{HTTP_HOST}/ra-aris-seo.html [R=301,L]
    # /ufaso-seo-auditi/ has 1 referring domain — literal "free SEO audit"
    RewriteRule ^ufaso-seo-auditi/?$     https://%{HTTP_HOST}/seo-audit.html [R=301,L]
    RewriteRule ^en/seo-optimizacia/?$   https://%{HTTP_HOST}/en/ra-aris-seo.html [R=301,L]
    RewriteRule ^en/ufaso-seo-auditi/?$  https://%{HTTP_HOST}/en/seo-audit.html [R=301,L]

    # ----- Website-info pages — were SEO analyses of OTHER sites (not our portfolio);
    # 0 clicks in GSC. 410 Gone = honest deindex signal (user confirmed 2026-05-13)
    RewriteRule ^website-info/[^/]+/?$   - [G,L]
    RewriteRule ^website-info/?$         - [G,L]

    # ----- WP feeds (RSS) — 410 Gone, faster deindex
    #       ORDER MATTERS: must come BEFORE /category/ rule or category catches /category/seo/feed/
    RewriteRule ^feed/?$                                - [G,L]
    RewriteRule ^comments/feed/?$                       - [G,L]
    RewriteRule ^.*/feed/?$                             - [G,L]

    # ----- WordPress categories → blog index -----
    RewriteRule ^category/.*$            https://%{HTTP_HOST}/blog.html [R=301,L]

    # ----- WordPress-only URL patterns (discovered via GSC) -----
    # Blog pagination: /blog/page/2/, /blog/page/3/, ...
    RewriteRule ^blog/page/[0-9]+/?$     https://%{HTTP_HOST}/blog.html [R=301,L]
    RewriteRule ^en/blog/page/[0-9]+/?$  https://%{HTTP_HOST}/en/blog.html [R=301,L]
    # Category pagination: /category/seo/page/2/, ...
    RewriteRule ^category/.+/page/[0-9]+/?$    https://%{HTTP_HOST}/blog.html [R=301,L]
    RewriteRule ^en/category/.+/page/[0-9]+/?$ https://%{HTTP_HOST}/en/blog.html [R=301,L]
    # WP tag pages
    RewriteRule ^tag/.*$                 https://%{HTTP_HOST}/blog.html [R=301,L]
    RewriteRule ^en/tag/.*$              https://%{HTTP_HOST}/en/blog.html [R=301,L]
    # WP author pages (with optional pagination)
    RewriteRule ^author/.*$              https://%{HTTP_HOST}/about-us.html [R=301,L]
    RewriteRule ^en/author/.*$           https://%{HTTP_HOST}/en/about-us.html [R=301,L]

    # ----- WP pages with NO CC equivalent but real impressions in GSC -----
    # /aeo-optimization-agency-dubai/ — Dubai expansion page (134 imp on /en/, 3 on GE)
    # Both GE and EN versions point to EN blog (content is English-only — Dubai market)
    RewriteRule ^aeo-optimization-agency-dubai/?$       https://%{HTTP_HOST}/en/blog/aeo-optimization-agency-dubai.html [R=301,L]
    RewriteRule ^en/aeo-optimization-agency-dubai/?$    https://%{HTTP_HOST}/en/blog/aeo-optimization-agency-dubai.html [R=301,L]

    # ----- Old WP /audit/SLUG/ pages (404 in GSC) → seo-audit -----
    RewriteRule ^audit/.*/?$                            https://%{HTTP_HOST}/seo-audit.html [R=301,L]
    RewriteRule ^en/audit/.*/?$                         https://%{HTTP_HOST}/en/seo-audit.html [R=301,L]

    # ----- Strip ad-platform click ID params (causes duplicate canonical issues in GSC)
    # Strips fbclid, gclid, msclkid — preserves utm_* (needed for analytics)
    RewriteCond %{QUERY_STRING} (^|&)(fbclid|gclid|msclkid)= [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1? [R=301,L]

    # ----- English mirror for the same static pages -----
    RewriteRule ^en/seo-management/?$    https://%{HTTP_HOST}/en/seo-management.html [R=301,L]
    RewriteRule ^en/seo-audit/?$         https://%{HTTP_HOST}/en/seo-audit.html [R=301,L]
    RewriteRule ^en/seo-copywriting/?$   https://%{HTTP_HOST}/en/seo-copywriting.html [R=301,L]
    RewriteRule ^en/copywriting/?$       https://%{HTTP_HOST}/en/blog/copywriting.html [R=301,L]
    RewriteRule ^en/local-seo/?$         https://%{HTTP_HOST}/en/blog/local-seo.html [R=301,L]
    RewriteRule ^en/about-us/?$          https://%{HTTP_HOST}/en/about-us.html [R=301,L]
    RewriteRule ^en/contact-us/?$        https://%{HTTP_HOST}/en/contact-us.html [R=301,L]
    RewriteRule ^en/portfolio/?$         https://%{HTTP_HOST}/en/portfolio.html [R=301,L]
    RewriteRule ^en/blog/?$              https://%{HTTP_HOST}/en/blog.html [R=301,L]
    # /en/seo-leqsikoni/ and /en/startup-leqsikoni/ — EN glossary pages don't exist; → blog
    RewriteRule ^en/seo-leqsikoni/?$     https://%{HTTP_HOST}/en/blog.html [R=301,L]
    RewriteRule ^en/startup-leqsikoni/?$ https://%{HTTP_HOST}/en/blog.html [R=301,L]
    RewriteRule ^en/case-studies/?$      https://%{HTTP_HOST}/en/case-studies.html [R=301,L]
    RewriteRule ^en/link-building/?$     https://%{HTTP_HOST}/en/seo-management.html [R=301,L]
    RewriteRule ^en/web-development/?$   - [G,L]
    RewriteRule ^en/get-an-offer/?$      https://%{HTTP_HOST}/en/contact-us.html [R=301,L]
    RewriteRule ^en/website-info/[^/]+/?$ - [G,L]
    RewriteRule ^en/website-info/?$      - [G,L]
    RewriteRule ^en/category/.*$         https://%{HTTP_HOST}/en/blog.html [R=301,L]

    # ----- English case studies (sub-dir trailing slash → .html) -----
    RewriteRule ^en/case-studies/3x-in-28-days/?$                       https://%{HTTP_HOST}/en/case-studies/3x-in-28-days.html [R=301,L]
    RewriteRule ^en/case-studies/270-percent-increase/?$                https://%{HTTP_HOST}/en/case-studies/270-percent-increase.html [R=301,L]
    RewriteRule ^en/case-studies/250-percent-increase/?$                https://%{HTTP_HOST}/en/case-studies/250-percent-increase.html [R=301,L]
    RewriteRule ^en/case-studies/local-seo-result/?$                    https://%{HTTP_HOST}/en/case-studies/local-seo-result.html [R=301,L]
    RewriteRule ^en/case-studies/stomatologiuri-klinikis-seo/?$         https://%{HTTP_HOST}/en/case-studies/stomatologiuri-klinikis-seo.html [R=301,L]
    RewriteRule ^en/case-studies/4200-yoveltviuri-vizitori-4-tveshi/?$  https://%{HTTP_HOST}/en/case-studies/4200-yoveltviuri-vizitori-4-tveshi.html [R=301,L]
    RewriteRule ^en/case-studies/trafikis-gaormageba-3-tveshi/?$        https://%{HTTP_HOST}/en/case-studies/trafikis-gaormageba-3-tveshi.html [R=301,L]
    RewriteRule ^en/case-studies/seo-krizisidan-top-3mde/?$             https://%{HTTP_HOST}/en/case-studies/seo-crisis-management.html [R=301,L]

    # ----- Catch-all #1: /slug/ → /slug.html if the file exists -----
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^([^/]+)/?$ https://%{HTTP_HOST}/$1.html [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/en/$1.html -f
    RewriteRule ^en/([^/]+)/?$ https://%{HTTP_HOST}/en/$1.html [R=301,L]

    # ----- Catch-all #2: /blog/slug/ → /blog/slug.html if file exists (handles WP blog post URLs we missed)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/blog/$1.html -f
    RewriteRule ^([^/]+)/?$ https://%{HTTP_HOST}/blog/$1.html [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/en/blog/$1.html -f
    RewriteRule ^en/([^/]+)/?$ https://%{HTTP_HOST}/en/blog/$1.html [R=301,L]

    # ----- Catch-all #3 (last resort): any unmapped /en/slug/ → /en/blog.html
    # Catches 22 WP /en/ blog URLs that have no CC equivalent — better than 404
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^en/[^/]+/?$ https://%{HTTP_HOST}/en/blog.html [R=301,L]
</IfModule>

# -----------------------------------------------------------------------------
# 3) Custom 404
# -----------------------------------------------------------------------------
ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# 4) Compression (gzip)  — Cloudways Apache supports mod_deflate
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript text/xml text/plain
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/rss+xml application/atom+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/otf font/ttf font/woff font/woff2 application/vnd.ms-fontobject
</IfModule>

# -----------------------------------------------------------------------------
# 5) Browser caching (Expires headers)
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"

    # HTML: 5 minutes — short enough that deploys propagate fast through Varnish + browser caches
    # but long enough that bots don't re-fetch every page on every request.
    ExpiresByType text/html                     "access plus 5 minutes"

    # XML/JSON: 5 minutes (sitemap.xml needs fast propagation too)
    ExpiresByType application/xml               "access plus 5 minutes"
    ExpiresByType text/xml                      "access plus 5 minutes"
    ExpiresByType application/json              "access plus 5 minutes"

    # CSS / JS: 1 year (versioned via deploy)
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType text/javascript               "access plus 1 year"

    # Images: 1 year
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"

    # Fonts: 1 year
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType font/otf                      "access plus 1 year"
    ExpiresByType font/ttf                      "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

    # Video
    ExpiresByType video/mp4                     "access plus 1 year"
</IfModule>

# Cache-Control headers (more granular)
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|jpg|jpeg|png|webp|gif|svg|ico|woff|woff2|otf|ttf|mp4)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(html|xml|json)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS — turn on AFTER you confirm HTTPS works on every URL (1 year + preload)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# -----------------------------------------------------------------------------
# 6) MIME types (some hosts miss these for modern formats)
# -----------------------------------------------------------------------------
<IfModule mod_mime.c>
    AddType image/webp                  .webp
    AddType image/avif                  .avif
    AddType font/woff2                  .woff2
    AddType application/manifest+json   .webmanifest
</IfModule>

# -----------------------------------------------------------------------------
# 7) Block hidden / sensitive files
# -----------------------------------------------------------------------------
<FilesMatch "^\.|\.md$|\.py$|\.pyc$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^(_cloudways|scripts|\.git|\.github)/  - [F,L]
</IfModule>
